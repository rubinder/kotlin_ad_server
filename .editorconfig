root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.{kt,kts}]
ij_kotlin_imports_layout = *,java.**,javax.**,kotlin.**,^
ktlint_standard_no-wildcard-imports = enabled
ktlint_standard_filename = enabled
max_line_length = 140

[*.{yml,yaml,json,md}]
indent_size = 2
